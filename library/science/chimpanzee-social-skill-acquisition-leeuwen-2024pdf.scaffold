      {
        "name": "Chimpanzees use social information to acquire a skill they fail to innovate",
        "type": "Product",
        "description": "Scientific article published in Nature Human Behaviour in March 2024, demonstrating that chimpanzees rely on social learning to acquire complex skills they cannot innovate independently.",
        "tags": [],
        "created": "2026-05-25T00:06:59.876Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Nature Human Behaviour",
        "type": "Organization",
        "description": "Scientific journal that published the study on chimpanzee social learning and cumulative cultural evolution.",
        "tags": [],
        "created": "2026-05-25T00:06:59.991Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Cumulative Cultural Evolution",
        "type": "Concept",
        "description": "Process by which incremental accumulations of changes to a cultural trait lead to functional improvement in performance, often considered a hallmark of human species success.",
        "tags": [],
        "created": "2026-05-25T00:07:00.106Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Social Learning",
        "type": "Concept",
        "description": "Mechanism by which individuals acquire know-how from others, deemed necessary and sufficient for chimpanzees to acquire new complex skills after initial innovation.",
        "tags": [],
        "created": "2026-05-25T00:07:00.222Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Puzzle Box",
        "type": "Tool",
        "description": "Sequential task device used in the study to test chimpanzee ability to operate a mechanism they previously failed to innovate on their own.",
        "tags": [],
        "created": "2026-05-25T00:07:00.339Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Network-based Diffusion Analysis",
        "type": "Concept",
        "description": "Analytical method used in the study to track how social information spread among chimpanzee groups and facilitated skill acquisition.",
        "tags": [],
        "created": "2026-05-25T00:07:00.454Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Zone of Latent Solutions",
        "type": "Concept",
        "description": "A hypothesis in animal culture debate proposing that apes do not copy know-how but individually re-invent behaviors which then become group-level traditions as an emergent property.",
        "tags": [],
        "created": "2026-05-25T00:07:49.467Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Know-how Copying",
        "type": "Concept",
        "description": "A specific type of social learning involving the acquisition of knowledge on the production of a particular trait, such as the mechanics of a tool or technique.",
        "tags": [],
        "created": "2026-05-25T00:07:49.595Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Individual Re-innovation",
        "type": "Concept",
        "description": "The process by which an animal invents a behavior on their own, cited by ZLS proponents as the primary mechanism for skill acquisition rather than social copying.",
        "tags": [],
        "created": "2026-05-25T00:07:49.712Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Group-level Traditions",
        "type": "Concept",
        "description": "Behaviors that become widespread within a group, viewed by ZLS proponents as an emergent property of individual re-innovations rather than direct social transmission of know-how.",
        "tags": [],
        "created": "2026-05-25T00:07:49.834Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Nut Cracking",
        "type": "Concept",
        "description": "A complex chimpanzee behavior often cited in debates about social learning, where ZLS proponents argue it is individually invented rather than socially copied.",
        "tags": [],
        "created": "2026-05-25T00:07:49.953Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Algae Scooping",
        "type": "Concept",
        "description": "A chimpanzee behavior involving the extraction of algae, used as evidence by ZLS proponents that captive apes can invent complex skills without prior social knowledge.",
        "tags": [],
        "created": "2026-05-25T00:07:50.069Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Nettle Feeding",
        "type": "Concept",
        "description": "A gorilla behavior involving the processing of nettles, cited in support of the Zone of Latent Solutions hypothesis as an individually invented skill.",
        "tags": [],
        "created": "2026-05-25T00:07:50.191Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Know-where",
        "type": "Concept",
        "description": "A form of social information transfer involving location data, distinguished from know-how copying in the ZLS framework.",
        "tags": [],
        "created": "2026-05-25T00:07:50.307Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Know-what",
        "type": "Concept",
        "description": "A form of social information transfer involving object or target identification, distinguished from know-how copying in the ZLS framework.",
        "tags": [],
        "created": "2026-05-25T00:07:50.432Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Arbitrary Human Gestures",
        "type": "Concept",
        "description": "Actions used in studies where great apes failed to copy them, serving as evidence for ZLS proponents that apes lack the capacity for certain types of social learning.",
        "tags": [],
        "created": "2026-05-25T00:07:50.559Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },

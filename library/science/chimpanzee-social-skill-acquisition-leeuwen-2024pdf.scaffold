      {
        "name": "Birds",
        "type": "Concept",
        "description": "Animal group cited in comparative studies where naive individuals selectively copied foraging techniques, providing evidence for know-how copying.",
        "tags": [],
        "created": "2026-05-25T00:08:32.911Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "High-fidelity Transmission",
        "type": "Concept",
        "description": "A mechanism of social learning characterized by precise copying of techniques, often associated with know-how copying and cumulative cultural evolution.",
        "tags": [],
        "created": "2026-05-25T00:08:33.031Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Low-fidelity Social Learning",
        "type": "Concept",
        "description": "Mechanisms such as stimulus and local enhancement that provide limited information and are insufficient for acquiring complex skills like nut cracking without know-how copying.",
        "tags": [],
        "created": "2026-05-25T00:08:33.152Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Stimulus Enhancement",
        "type": "Concept",
        "description": "A low-fidelity social learning mechanism where attention is drawn to an object or location, but does not convey the mechanics of action.",
        "tags": [],
        "created": "2026-05-25T00:08:37.413Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Local Enhancement",
        "type": "Concept",
        "description": "A low-fidelity social learning mechanism where an individual is attracted to a specific location due to the presence of others, without learning the specific behavior.",
        "tags": [],
        "created": "2026-05-25T00:08:37.540Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Termite Fishing",
        "type": "Concept",
        "description": "A complex chimpanzee foraging technique involving composite tool use, cited in recent studies as evidence for process-oriented imitation and cumulative cultural diversity in wild populations.",
        "tags": [],
        "created": "2026-05-25T00:09:18.443Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Chimfunshi Wildlife Orphanage Trust",
        "type": "Organization",
        "description": "An African sanctuary located in Zambia that hosts semi-wild chimpanzees and served as the site for the controlled behavioral experiment on skill acquisition.",
        "tags": [],
        "created": "2026-05-25T00:09:19.733Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Homing Pigeons",
        "type": "Concept",
        "description": "Subject of an experimental study on flying routes that challenged the assumption that know-how copying is essential for cumulative cultural evolution.",

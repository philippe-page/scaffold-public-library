      },
      {
        "from": "Proficient Conspecific Model",
        "to": "Social Transmission",
        "type": "INITIATES",
        "properties": {
          "context": "Seeded one proficient model in each group to test social learning capabilities."
        }
      },
      {
        "from": "Proficient Conspecific Model",
        "to": "Task Solution Observation",
        "type": "PROVIDES",
        "properties": {
          "context": "The trained demonstrator provided the successful task manipulations observed by the naive chimpanzees."
        }
      },
      {
        "from": "Opaque Sequence of Behaviours",
        "to": "Social Learning",
        "type": "DEPENDS_ON",
        "properties": {
          "context": "Learning this sequence is substantially less probable in the absence of relevant social information."
        }
      },
      {
        "from": "Opaque Sequence of Behaviours",
        "to": "Temporal Order Requirement",
        "type": "REQUIRES",
        "properties": {
          "context": "The opaque sequence requires actions to be executed in a specific temporal order, substantially complicating the task and preventing independent invention."
        }
      },
      {
        "from": "Opaque Sequence of Behaviours",
        "to": "Space of Know-how",
        "type": "OUTSIDE_OF",
        "properties": {
          "context": "The required skill sequence did not readily transpire out of the chimpanzees' imagined space of know-how, indicating it was beyond their individual inventive capacity."
        }
      },
      {
        "from": "Conducive Ecological Environment",
        "to": "Forested Home-range Territory",
        "type": "LOCATED_IN",
        "properties": {

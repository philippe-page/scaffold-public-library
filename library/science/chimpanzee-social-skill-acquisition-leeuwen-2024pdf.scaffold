        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Process-oriented Imitation",
        "type": "Concept",
        "description": "A form of social learning inferred from the community-specific complexity of termite fishing techniques, involving the copying of the procedural elements of a behavior.",
        "tags": [],
        "created": "2026-05-25T00:09:20.001Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },
      {
        "name": "Two-action Methodology",
        "type": "Concept",
        "description": "An experimental paradigm used to test social learning where two different techniques (e.g., poking and lifting) are typically invented by individuals in control conditions, supporting the ZLS argument that know-how copying is not required for these behaviors.",
        "tags": [],
        "created": "2026-05-25T00:10:13.892Z",
        "source": "chimpanzee-social-skill-acquisition-leeuwen-2024.pdf"
      },

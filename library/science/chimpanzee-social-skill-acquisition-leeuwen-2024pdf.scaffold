        }
      },
      {
        "from": "Age",
        "to": "Social Transmission",
        "type": "NO_INFLUENCE_ON",
        "properties": {
          "context": "The study found no support for the influence of age on the rate of social learning."
        }
      },
      {
        "from": "Group Network Hypothesis",
        "to": "Social Transmission",
        "type": "SUPPORTS_HYPOTHESIS",
        "properties": {
          "context": "This hypothesis, stating transmission follows within-group observation patterns, received 65.3 times more support than the group network model."
        }
      },
      {
        "from": "Response Facilitation",
        "to": "Zone of Latent Solutions",
        "type": "SUPPORTS_HYPOTHESIS",
        "properties": {
          "context": "Inferred by ZLS proponents as the mechanism at play in certain studies, suggesting use of familiar actions in novel contexts rather than new know-how acquisition."
        }
      },
      {
        "from": "Socially Learned Tradition",
        "to": "Zone of Latent Solutions",
        "type": "EXCEEDS_CAPACITY_OF",
        "properties": {
          "context": "The tradition allows mastery beyond the chimpanzees' ZLS, indicating reliance on social transmission rather than individual innovation."
        }
      },
      {
        "from": "Socially Learned Tradition",
        "to": "Cumulative Cultural Evolution",
        "type": "ENABLES",
        "properties": {
          "context": "Socially learned traditions transmitted over generations are a prerequisite for cumulative cultural evolution, which individual chimpanzees cannot develop independently."
        }
      },
      {
        "from": "Barbary Macaques",
        "to": "Rotating Door Task",
        "type": "PERFORMED_TASK",

        "name": "USC School of Cinematic Arts",
        "type": "Organization",
        "description": "The University of Southern California film school where Frank Daniel served as dean.",
        "context": "Connected to Frank Daniel through his role as dean.",
        "tags": [
          "film-school",
          "education"
        ],
        "created": "2026-05-23T21:18:16.579Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Dramatica",
        "type": "Concept",
        "description": "A story theory framework associated with Melanie Anne Phillips and Chris Huntley that treats stories as fractal structures composed of nested narrative units.",
        "context": "Referenced as an influence on the author's thinking about modular storytelling in games.",
        "tags": [
          "story-theory",
          "narrative-structure"
        ],
        "created": "2026-05-23T21:18:17.608Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Melanie Anne Phillips",
        "type": "Person",
        "description": "Story theory writer and co-creator associated with Dramatica, cited for the idea that stories are fractal.",
        "context": "Mentioned as one of the people whose work on Dramatica influenced the author's understanding of storytelling structure.",
        "tags": [
          "story-theory",
          "writer"
        ],
        "created": "2026-05-23T21:18:18.386Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Chris Huntley",
        "type": "Person",
        "description": "Story theory writer and co-creator associated with Dramatica, cited for the idea that stories are fractal.",
        "context": "Mentioned as one of the people whose work on Dramatica influenced the author's understanding of storytelling structure.",
        "tags": [
          "story-theory",
          "writer"
        ],
        "created": "2026-05-23T21:18:18.689Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Fractal storytelling",
        "type": "Concept",
        "description": "The idea that stories are recursively composed of similar nested units, such as acts, sequences, scenes, and beats.",
        "context": "Used to describe a recursive narrative pattern that influenced the author's approach to games and storytelling.",
        "tags": [
          "storytelling",
          "fractal",
          "structure"
        ],
        "created": "2026-05-23T21:18:18.913Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Beginning-middle-end",
        "type": "Concept",
        "description": "A basic narrative pattern repeated at multiple scales in stories and gameplay fragments to create varied but coherent experiences.",
        "context": "Used to describe modular storytelling and gameplay as repeating narrative units.",
        "tags": [
          "narrative",
          "structure"
        ],
        "created": "2026-05-23T21:18:19.140Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Gameplay fragment",
        "type": "Concept",
        "description": "A small unit of play that can be analyzed as a beginning-middle-end pattern and combined with others to produce larger effects.",
        "context": "Mentioned as one of the modular pieces that can be deliberately collaged together.",
        "tags": [
          "game-design",
          "gameplay"
        ],
        "created": "2026-05-23T21:18:19.357Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Audience of players",
        "type": "Group",
        "description": "The players for whom gameplay and story fragments are deliberately combined to create thrilling and moving effects.",

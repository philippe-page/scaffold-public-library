      {
        "name": "Player goals",
        "type": "Concept",
        "description": "The immediate aims a player is pursuing at any given moment during play, which can be aligned or misaligned with the player-character's goals.",
        "context": "Part of a design framework for making game stories work well.",
        "tags": [
          "game design",
          "player psychology"
        ],

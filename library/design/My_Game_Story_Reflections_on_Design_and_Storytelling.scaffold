      {
        "name": "Game storytelling",
        "type": "Concept",
        "description": "Storytelling in games that is strengthened when gameplay, narrative, psychology, and context are braided together to align player and character motivations.",
        "context": "Presented as the outcome of effective alignment between player and player-character goals.",

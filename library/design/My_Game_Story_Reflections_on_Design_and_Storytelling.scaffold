      {
        "name": "The gap",
        "type": "Concept",
        "description": "Robert McKee's term for the difference between what a protagonist expects when taking an action and what actually happens, used to analyze dramatic structure.",
        "context": "Applied by the Uncharted team to understand expectation versus outcome in storytelling.",
        "tags": [
          "narrative-theory",
          "screenwriting"
        ],
        "created": "2026-05-23T21:17:41.551Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Three-act structure",
        "type": "Concept",
        "description": "An Aristotelian dramatic framework that organizes a story into setup, development, and resolution.",
        "context": "Presented as a story structure model useful for game designers and tied to tidy beginning-middle-end progression.",
        "tags": [
          "story structure",
          "dramaturgy"
        ],
        "created": "2026-05-23T21:17:54.919Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Freytag's pyramid",
        "type": "Concept",
        "description": "A classic dramatic structure model that maps narrative intensity through a rising-and-falling pyramid shape.",
        "context": "Mentioned alongside three-act structure as a way for game developers to recognize narrative patterns in games and stories.",
        "tags": [
          "story structure",
          "narrative theory"
        ],
        "created": "2026-05-23T21:17:55.143Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Intensity",
        "type": "Concept",
        "description": "The level of dramatic or gameplay force at a given moment, which can rise and fall across both stories and games.",
        "context": "Used to describe peaks in gameplay and story that can either reinforce or cancel each other.",
        "tags": [
          "gameplay",
          "storytelling"
        ],
        "created": "2026-05-23T21:17:55.874Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Exploration",
        "type": "Concept",
        "description": "A quieter gameplay mode centered on movement, observation, and discovery rather than combat.",
        "context": "Used in contrast with intense action gameplay in Uncharted to give the story room to breathe.",

      {
        "name": "sequence structure",
        "type": "Concept",
        "description": "A storytelling model proposed by Frank Daniel in which acts are broken into sequences that function as miniature stories, each leading into the next.",
        "context": "Used to explain how stories can be modular and broken into nested units of meaning.",
        "tags": [
          "storytelling",
          "structure",
          "screenwriting"
        ],
        "created": "2026-05-23T21:18:15.959Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },
      {
        "name": "Frank Daniel",
        "type": "Person",
        "description": "Czech-American screenwriter, film director, and former dean of the USC School of Cinematic Arts who proposed sequence structure as a storytelling model.",
        "context": "Cited as the originator of a model that treats acts and sequences as nested narrative units.",
        "tags": [
          "screenwriter",
          "filmmaker",
          "educator"
        ],
        "created": "2026-05-23T21:18:16.206Z",
        "source": "https://thereader.mitpress.mit.edu/my-game-story-reflections-on-design-and-storytelling/"
      },

      },
      {
        "name": "Hewlett-Packard",
        "type": "Organization",
        "description": "Technology company where a 12-year-old Steve Jobs secured spare parts and a summer job after directly calling Bill Hewlett. The experience had a remarkable influence on his early development.",
        "tags": [],

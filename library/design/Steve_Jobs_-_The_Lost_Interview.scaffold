      },
      {
        "name": "Time-sharing terminal",
        "type": "Product",
        "description": "A teletype printer with a keyboard used to interact with mainframe computers remotely. Jobs used this primitive interface to write programs in BASIC or Fortran without seeing the actual computer.",
        "tags": [],
        "created": "2026-05-27T22:14:44.737Z",
        "source": "https://www.youtube.com/watch?v=TRZAJY23xio"
      },
      {

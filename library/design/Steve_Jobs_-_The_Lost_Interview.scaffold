        }
      },
      {
        "from": "Software Performance Dynamic Range",
        "to": "CD Player Quality Comparison",
        "type": "CONTRASTS_WITH",
        "properties": {
          "context": "Jobs used the CD player analogy (20% difference) to illustrate the standard narrow dynamic range in most industries, contrasting it with the 50-100x gap in software."
        }
      },
      {
        "from": "Bill Atkinson",
        "to": "Direct Feedback Culture",
        "type": "ILLUSTRATES",
